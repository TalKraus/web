# .env.example - Copy to .env and fill in values
# TechRent Pro - Environment Variables

# Flask secret key for session signing (generate a random string)
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# Flask debug mode (true/false)
FLASK_DEBUG=false

# Server settings
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
